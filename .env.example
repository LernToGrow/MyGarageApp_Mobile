# Backend API base URL — use your machine's LAN IP for Expo Go testing
EXPO_PUBLIC_API_URL=http://192.168.1.100:5000/api

# Firebase Web App config (from Firebase Console → Project Settings → Your Apps)
# These are PUBLIC client-side values — safe to commit to a private repo.
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
